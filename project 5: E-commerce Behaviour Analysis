# ==========================================
# E-Commerce Customer Behavior Analysis
# ==========================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# ------------------------------------------
# Load Dataset
# ------------------------------------------

df = pd.read_csv("ecommerce_data.csv")

print("\nDataset Preview")
print(df.head())

# ------------------------------------------
# Data Cleaning
# ------------------------------------------

print("\nMissing Values")
print(df.isnull().sum())

# ------------------------------------------
# Create Total Purchase Amount
# ------------------------------------------

df["TotalAmount"] = df["Quantity"] * df["Price"]

print("\nUpdated Dataset")
print(df.head())

# ------------------------------------------
# Basic Statistics
# ------------------------------------------

print("\nDescriptive Statistics")
print(df.describe())

# ------------------------------------------
# Customer Spending Analysis
# ------------------------------------------

customer_spending = df.groupby("CustomerID")["TotalAmount"].sum()

print("\nCustomer Spending")
print(customer_spending)

# ------------------------------------------
# Top Spending Customers
# ------------------------------------------

top_customers = customer_spending.sort_values(
                    ascending=False).head(5)

print("\nTop 5 Customers")
print(top_customers)

# ------------------------------------------
# Category-wise Sales
# ------------------------------------------

category_sales = df.groupby("Category")["TotalAmount"].sum()

print("\nCategory Sales")
print(category_sales)

# ------------------------------------------
# Product-wise Sales
# ------------------------------------------

product_sales = df.groupby("Product")["TotalAmount"].sum()

print("\nProduct Sales")
print(product_sales)

# ------------------------------------------
# Gender-wise Spending
# ------------------------------------------

gender_spending = df.groupby("Gender")["TotalAmount"].sum()

print("\nGender Spending")
print(gender_spending)

# ------------------------------------------
# Average Age of Customers
# ------------------------------------------

print("\nAverage Customer Age:",
      round(df["Age"].mean(), 2))

# ------------------------------------------
# Visualization 1
# Category Sales
# ------------------------------------------

plt.figure(figsize=(8,5))

category_sales.plot(
    kind='bar',
    color='skyblue'
)

plt.title("Category-wise Sales")
plt.ylabel("Sales Amount")
plt.xlabel("Category")
plt.xticks(rotation=45)
plt.show()

# ------------------------------------------
# Visualization 2
# Gender Spending
# ------------------------------------------

plt.figure(figsize=(6,4))

gender_spending.plot(
    kind='pie',
    autopct='%1.1f%%'
)

plt.title("Gender-wise Spending")
plt.ylabel("")
plt.show()

# ------------------------------------------
# Visualization 3
# Age Distribution
# ------------------------------------------

plt.figure(figsize=(8,5))

sns.histplot(
    df["Age"],
    bins=8,
    kde=True
)

plt.title("Customer Age Distribution")
plt.xlabel("Age")
plt.ylabel("Frequency")
plt.show()

# ------------------------------------------
# Visualization 4
# Top Products
# ------------------------------------------

plt.figure(figsize=(8,5))

product_sales.sort_values(
    ascending=False
).plot(
    kind='bar'
)

plt.title("Product Sales")
plt.ylabel("Revenue")
plt.xlabel("Products")
plt.show()

# ------------------------------------------
# Customer Segmentation
# ------------------------------------------

conditions = [
    df["TotalAmount"] < 5000,
    (df["TotalAmount"] >= 5000) &
    (df["TotalAmount"] < 25000),
    df["TotalAmount"] >= 25000
]

segments = [
    "Low Value",
    "Medium Value",
    "High Value"
]

df["CustomerSegment"] = np.select(
    conditions,
    segments,
    default="Low Value"
)

print("\nCustomer Segments")
print(df[["CustomerID",
          "TotalAmount",
          "CustomerSegment"]])

# ------------------------------------------
# Segment Count
# ------------------------------------------

segment_count = df["CustomerSegment"].value_counts()

print("\nSegment Distribution")
print(segment_count)

plt.figure(figsize=(7,5))

segment_count.plot(
    kind='bar',
    color='orange'
)

plt.title("Customer Segments")
plt.xlabel("Segment")
plt.ylabel("Count")
plt.show()

# ------------------------------------------
# Save Analysis Report
# ------------------------------------------

df.to_csv(
    "customer_behavior_report.csv",
    index=False
)

print("\nAnalysis Completed Successfully!")
print("Report saved as customer_behavior_report.csv")
