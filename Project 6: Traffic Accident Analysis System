# ==========================================
# Traffic Accident Analysis System
# ==========================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# ------------------------------------------
# Load Dataset
# ------------------------------------------

df = pd.read_csv("traffic_accidents.csv")

print("\nTraffic Accident Dataset")
print(df.head())

# ------------------------------------------
# Dataset Information
# ------------------------------------------

print("\nDataset Information")
print(df.info())

print("\nMissing Values")
print(df.isnull().sum())

# ------------------------------------------
# Total Accidents
# ------------------------------------------

total_accidents = df["Accidents"].sum()

print("\nTotal Accidents:", total_accidents)

# ------------------------------------------
# Location-wise Analysis
# ------------------------------------------

location_analysis = df.groupby(
    "Location"
)["Accidents"].sum()

print("\nLocation-wise Accidents")
print(location_analysis)

# ------------------------------------------
# Vehicle Type Analysis
# ------------------------------------------

vehicle_analysis = df.groupby(
    "VehicleType"
)["Accidents"].count()

print("\nVehicle-wise Accidents")
print(vehicle_analysis)

# ------------------------------------------
# Weather Analysis
# ------------------------------------------

weather_analysis = df.groupby(
    "Weather"
)["Accidents"].count()

print("\nWeather Impact")
print(weather_analysis)

# ------------------------------------------
# Severity Analysis
# ------------------------------------------

severity_analysis = df.groupby(
    "Severity"
)["Accidents"].count()

print("\nSeverity Analysis")
print(severity_analysis)

# ------------------------------------------
# Time Analysis
# ------------------------------------------

time_analysis = df.groupby(
    "Time"
)["Accidents"].count()

print("\nTime-wise Analysis")
print(time_analysis)

# ------------------------------------------
# Severity Score Mapping
# ------------------------------------------

severity_map = {
    "Minor":1,
    "Major":2,
    "Critical":3
}

df["SeverityScore"] = df[
    "Severity"
].map(severity_map)

print("\nDataset with Severity Score")
print(df.head())

# ------------------------------------------
# High Risk Locations
# ------------------------------------------

risk_locations = df.groupby(
    "Location"
)["SeverityScore"].mean()

print("\nAverage Risk Score")
print(risk_locations)

# ------------------------------------------
# Most Accident-Prone Location
# ------------------------------------------

danger_zone = risk_locations.idxmax()

print("\nMost Accident-Prone Location:")
print(danger_zone)

# ==========================================
# VISUALIZATIONS
# ==========================================

sns.set_style("whitegrid")

# ------------------------------------------
# 1. Location-wise Accidents
# ------------------------------------------

plt.figure(figsize=(8,5))

location_analysis.plot(
    kind="bar",
    color="skyblue"
)

plt.title("Location-wise Accident Count")
plt.xlabel("Location")
plt.ylabel("Accidents")
plt.show()

# ------------------------------------------
# 2. Vehicle Type Analysis
# ------------------------------------------

plt.figure(figsize=(8,5))

vehicle_analysis.plot(
    kind="bar",
    color="green"
)

plt.title("Vehicle-wise Accidents")
plt.xlabel("Vehicle Type")
plt.ylabel("Count")
plt.show()

# ------------------------------------------
# 3. Weather Analysis
# ------------------------------------------

plt.figure(figsize=(7,7))

weather_analysis.plot(
    kind="pie",
    autopct="%1.1f%%"
)

plt.title("Weather Impact on Accidents")
plt.ylabel("")
plt.show()

# ------------------------------------------
# 4. Severity Analysis
# ------------------------------------------

plt.figure(figsize=(8,5))

severity_analysis.plot(
    kind="bar",
    color="red"
)

plt.title("Severity Distribution")
plt.xlabel("Severity")
plt.ylabel("Count")
plt.show()

# ------------------------------------------
# 5. Time-wise Analysis
# ------------------------------------------

plt.figure(figsize=(8,5))

time_analysis.plot(
    kind="line",
    marker="o"
)

plt.title("Accidents by Time")
plt.xlabel("Time")
plt.ylabel("Count")
plt.grid(True)
plt.show()

# ------------------------------------------
# 6. Heatmap Analysis
# ------------------------------------------

pivot_table = pd.crosstab(
    df["Location"],
    df["Severity"]
)

plt.figure(figsize=(8,5))

sns.heatmap(
    pivot_table,
    annot=True,
    cmap="YlOrRd"
)

plt.title("Location vs Severity Heatmap")
plt.show()

# ------------------------------------------
# Save Report
# ------------------------------------------

df.to_csv(
    "Traffic_Accident_Report.csv",
    index=False
)

print("\nAnalysis Completed Successfully!")
print("Report Saved: Traffic_Accident_Report.csv")
